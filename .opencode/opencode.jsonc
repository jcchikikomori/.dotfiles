{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "default_agent": "dotfiles-orchestrator",
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "plugin": [
    "opencode-redactor@0.1.1",
    "envsitter-guard@latest"
  ],
  "provider": {
    "github-copilot": {},
    "amazon-bedrock": {
      "options": {
        "region": "{env:AWS_REGION}",
        "profile": "{env:AWS_PROFILE}"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.2:latest": {
          "name": "llama3.2"
        },
        "qwen3:8b": {
          "name": "qwen3:8b"
        }
      }
    }
  },
  "mcp": {
    "github-mcp": {
      "enabled": true
    },
    "stackoverflow-mcp": {
      "enabled": true
    },
    "framelink-figma": {
      "enabled": false
    },
    "atlassian-mcp": {
      "enabled": false
    },
    "sonarqube-mcp": {
      "enabled": false
    }
  }
}
