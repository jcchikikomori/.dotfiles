#!/bin/sh

# Sync RetroArch saves, states, configuration overrides, NVRAM, and cheats to MEGA S4 bucket
# Follows EmuDeck's standardized directory structure

# Default path for Emulation folder
DEFAULT_EMULATION_DIR="$HOME/Emulation"

# Check if the default path exists
if [ -d "$DEFAULT_EMULATION_DIR" ]; then
    EMULATION_DIR="$DEFAULT_EMULATION_DIR"
else
    # Prompt the user for the correct path
    echo "Default Emulation directory not found at $DEFAULT_EMULATION_DIR."
    echo "If you have EmuDeck installed in a custom or external location, please provide its full path."
    read -r -p "Enter the path to your Emulation folder: " CUSTOM_PATH

    # Verify the user-provided path exists
    if [ -d "$CUSTOM_PATH" ]; then
        EMULATION_DIR="$CUSTOM_PATH"
    else
        echo "ERROR: Invalid path. Emulation directory not found at $CUSTOM_PATH" >&2
        exit 1
    fi
fi

# Define RetroArch paths (EmuDeck standard)
RETROARCH_SAVES="$EMULATION_DIR/saves/retroarch/saves"
RETROARCH_STATES="$EMULATION_DIR/saves/retroarch/states"
RETROARCH_CONFIG="$EMULATION_DIR/saves/retroarch/config"
RETROARCH_SYSTEM="$HOME/.config/retroarch/system"
RETROARCH_CHEATS="$HOME/.config/retroarch/cheats"

echo "Syncing RetroArch data to mega:emudeck-data/retroarch..."
echo ""
echo "Items being synced:"
echo "  - Save files (saves/)"
echo "  - Save states (states/)"
echo "  - Configuration overrides (config/)"
echo "    • Core-specific configs (.cfg files)"
echo "    • Shader presets (.slangp, .glslp files)"
echo "    • Controller remaps (.rmp files)"
echo "  - NVRAM files (system/ - service menu configs)"
echo "  - Cheat files (cheats/)"
echo ""

# Sync save files
if [ -d "$RETROARCH_SAVES" ]; then
    echo "Syncing save files..."
    rclone sync "$RETROARCH_SAVES/" "mega:emudeck-data/retroarch/saves" --verbose --copy-links
else
    echo "⚠ Save files directory not found at $RETROARCH_SAVES (skipping)"
fi

# Sync save states
if [ -d "$RETROARCH_STATES" ]; then
    echo "Syncing save states..."
    rclone sync "$RETROARCH_STATES/" "mega:emudeck-data/retroarch/states" --verbose --copy-links
else
    echo "⚠ Save states directory not found at $RETROARCH_STATES (skipping)"
fi

# Sync configuration overrides
if [ -d "$RETROARCH_CONFIG" ]; then
    echo "Syncing configuration overrides..."
    rclone sync "$RETROARCH_CONFIG/" "mega:emudeck-data/retroarch/config" --verbose --copy-links
else
    echo "⚠ Configuration directory not found at $RETROARCH_CONFIG (skipping)"
fi

# Sync NVRAM files (service menu configurations, edited configurations)
if [ -d "$RETROARCH_SYSTEM" ]; then
    echo "Syncing NVRAM files..."
    rclone sync "$RETROARCH_SYSTEM/" "mega:emudeck-data/retroarch/nvram" --verbose --copy-links --include="*.nvram" --include="*.bin"
else
    echo "⚠ NVRAM directory not found at $RETROARCH_SYSTEM (skipping)"
fi

# Sync cheat files
if [ -d "$RETROARCH_CHEATS" ]; then
    echo "Syncing cheat files..."
    rclone sync "$RETROARCH_CHEATS/" "mega:emudeck-data/retroarch/cheats" --verbose --copy-links
else
    echo "⚠ Cheat files directory not found at $RETROARCH_CHEATS (skipping)"
fi

echo ""
echo "✓ RetroArch data synced successfully to mega:emudeck-data/retroarch/"