#compdef dotfiles-git-repo

# Zsh completion for dotfiles-git-repo

_dotfiles-git-repo() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1: :->command'

  case "$state" in
    command)
      _values 'dotfiles-git-repo command' \
        'initialize[Initialize Git with pre-commit support]' \
        'precommit[Initialize pre-commit support (without git init)]' \
        'czhook[Install the commitizen wizard hook (prepare-commit-msg) only]' \
        'validate[Validate the repository initialization]' \
        'help[Show help]'
      ;;
  esac
}

_dotfiles-git-repo "$@"
