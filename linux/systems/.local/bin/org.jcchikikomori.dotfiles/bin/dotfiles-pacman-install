#!/bin/sh

# Shared pacman install helper for Arch-based systems.
# Source this file to get is_forced_package(), pacman_install(), and
# confirm_aur_install() functions. The sourcing script must define log_info()
# before calling confirm_aur_install().

# Space-separated package list to force install on file conflicts.
# Example: PACMAN_FORCE_CONFLICT_PACKAGES="python3 openssh" dotfiles-arch setup
PACMAN_FORCE_CONFLICT_PACKAGES="${PACMAN_FORCE_CONFLICT_PACKAGES:-}"
PACMAN_OVERWRITE_GLOB="${PACMAN_OVERWRITE_GLOB:-*}"

is_forced_package() {
  package_name="$1"
  for forced_pkg in $PACMAN_FORCE_CONFLICT_PACKAGES; do
    if [ "$forced_pkg" = "$package_name" ]; then
      return 0
    fi
  done
  return 1
}

pacman_install() {
  pacman_args="$1"
  shift

  regular_packages=""
  forced_packages=""

  for package_name in "$@"; do
    if is_forced_package "$package_name"; then
      forced_packages="$forced_packages $package_name"
    else
      regular_packages="$regular_packages $package_name"
    fi
  done

  if [ -n "$regular_packages" ]; then
    sudo pacman $pacman_args $regular_packages || return 1
  fi

  if [ -n "$forced_packages" ]; then
    echo "Installing forced packages with overwrite glob: $PACMAN_OVERWRITE_GLOB"
    sudo pacman $pacman_args --overwrite "$PACMAN_OVERWRITE_GLOB" $forced_packages || return 1
  fi
}

# Prompt to confirm installing an AUR package. Returns 0 to proceed, 1 to skip.
# Skips the prompt entirely in CI or when SKIP_INSTALL_PROGLANG is set.
confirm_aur_install() {
  package_name="$1"

  CI_MODE="${CI:-false}"
  if [ "$CI_MODE" = "true" ] || [ -n "${SKIP_INSTALL_PROGLANG:-}" ]; then
    return 0
  fi

  echo ""
  echo "WARNING: Installing AUR package: $package_name"
  echo "Source: AUR (Arch User Repository)"
  echo "Supply chain risk: AUR packages are maintained by volunteers and may become"
  echo "orphaned, compromised, or contain malicious code. See:"
  echo "  https://archlinux.org/news/active-aur-malicious-packages-incident/"
  echo ""
  printf "Continue with installation? [Y/n] "
  read -r confirm || confirm=n
  case "$confirm" in
    [nN]|[nN][oO])
      log_info "Skipping $package_name (user declined)"
      return 1
      ;;
  esac
}
