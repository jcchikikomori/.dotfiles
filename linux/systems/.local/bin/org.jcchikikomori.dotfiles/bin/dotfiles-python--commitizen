#!/bin/sh

echo "Installing commitizen (cz)..."
WORKDIR=$(mktemp -d)
PYENV_ROOT="$HOME/.pyenv"
trap 'rm -rf "$WORKDIR"' EXIT

# Install commitizen using the best available method.
# Handles: pip/pip3 (with or without venv), uv tool, pyenv.
install_commitizen() {
    # Already installed?
    if command -v cz >/dev/null 2>&1; then
        echo "commitizen is already installed. Exiting..."
        exit 0
    fi

    # Helper: install via pip, dropping --user if inside a venv
    _pip_install() {
        local pip_cmd="$1"
        if [ -n "$VIRTUAL_ENV" ]; then
            echo "  (inside venv, using pip without --user)"
            $pip_cmd install commitizen
        else
            $pip_cmd install --user commitizen
        fi
    }

    # Strategy 1: pip or pip3 directly available
    if command -v pip >/dev/null 2>&1; then
        echo "Installing commitizen via pip..."
        _pip_install pip || { echo "Error: Failed to install commitizen via pip." >&2; exit 1; }
        exit 0
    fi
    if command -v pip3 >/dev/null 2>&1; then
        echo "Installing commitizen via pip3..."
        _pip_install pip3 || { echo "Error: Failed to install commitizen via pip3." >&2; exit 1; }
        exit 0
    fi

    # Strategy 2: uv tool install (no --user issue, uv manages its own venvs)
    if command -v uv >/dev/null 2>&1; then
        echo "Installing commitizen via uv tool..."
        uv tool install commitizen || { echo "Error: Failed to install commitizen via uv." >&2; exit 1; }
        exit 0
    fi

    # Strategy 3: pyenv
    if [ -d "$PYENV_ROOT" ]; then
        echo "pyenv found. Loading pyenv environment..."
        export PATH="$PYENV_ROOT/bin:$PATH"
        eval "$(pyenv init -)"

        LATEST_VERSION=$(pyenv versions --bare | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -n 1)
        if [ -n "$LATEST_VERSION" ]; then
            echo "Setting Python $LATEST_VERSION as the global version..."
            pyenv global "$LATEST_VERSION"
            pyenv rehash
            if command -v pip >/dev/null 2>&1; then
                _pip_install pip || { echo "Error: Failed to install commitizen." >&2; exit 1; }
            elif command -v pip3 >/dev/null 2>&1; then
                _pip_install pip3 || { echo "Error: Failed to install commitizen." >&2; exit 1; }
            else
                echo "Error: pip not found after loading pyenv." >&2
                exit 1
            fi
            exit 0
        else
            echo "Error: No Python versions found in pyenv." >&2
            exit 1
        fi
    fi

    # Fallback: system python3 -m pip (last resort)
    if command -v python3 >/dev/null 2>&1; then
        echo "Falling back to python3 -m pip..."
        if [ -n "$VIRTUAL_ENV" ]; then
            python3 -m pip install commitizen || { echo "Error: Failed to install commitizen." >&2; exit 1; }
        else
            python3 -m pip install --user commitizen || { echo "Error: Failed to install commitizen." >&2; exit 1; }
        fi
        exit 0
    fi

    echo "Error: No supported Python manager found." >&2
    echo "  Supported: pip/pip3, uv, pyenv, python3 -m pip" >&2
    echo "  Please install Python via dotfiles-python first." >&2
    exit 1
}

# Detect Termux environment
if [ -n "$PREFIX" ] && echo "$PREFIX" | grep -q "com.termux"; then
    echo ""
    echo "=== Termux Environment Detected ==="
    echo "Installing commitizen via pip in Termux..."
    install_commitizen
else
    install_commitizen
fi
