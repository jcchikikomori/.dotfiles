#     fi
# }

prompt_installation() {
    local name=$1
    local script=$2
    local default_choice="y"

    if [ -n "${SKIP_INSTALL_PROGLANG}" ]; then
        echo "Unattended mode: Skipping $name installation"
        return
    fi

    echo "Do you want to install $name? (y/n): " >&2
    read choice
    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
        echo "Executing $name..."
        if [ "$script" = "dotfiles-python" ]; then
            $WORKDIR/$script install
        elif [ "$script" = "dotfiles-php" ]; then
            $WORKDIR/$script install
        elif [ "$script" = "dotfiles-ruby" ]; then
            $WORKDIR/$script install
        elif [ "$script" = "dotfiles-copyparty" ]; then
            $WORKDIR/$script install
        else
            $WORKDIR/$script
        fi
    else
        echo "Skipped. You can install $name later."
    fi
}

# Setup ~/.profile.local for user customizations
setup_profile_local() {
    local profile_local="$HOME/.profile.local"

    # Check if already exists
    if [ -f "$profile_local" ]; then
        echo "[INFO] ~/.profile.local already exists, skipping"
        return 0
    fi

    # CI/Unattended mode - auto create with defaults
    if [ "$CI_MODE" = "true" ] || [ -n "$SKIP_INSTALL_PROGLANG" ]; then
        local dotfiles_dir="${DOTFILES_PATH:-$HOME/.dotfiles}"
        local example_file="$dotfiles_dir/.profile.local.example"
        if [ -f "$example_file" ]; then
            cp "$example_file" "$profile_local"
            echo "[INFO] Created ~/.profile.local from example (CI mode)"
        else
            echo "[WARN] Example file not found: $example_file"
            echo "[WARN] Skipping ~/.profile.local creation"
        fi
        return 0
    fi

    # Interactive mode - ask user
    echo ""
    echo "Would you like to create ~/.profile.local for your customizations?"
    echo "This file will NOT be managed by dotfiles and persists across updates."
    echo "Your ~/.profile will source it automatically."
    printf "%s [y/N] " "Create ~/.profile.local?"
    read -r choice
    case "$choice" in
        [yY]|[yY][eE][sS])
            local dotfiles_dir="${DOTFILES_PATH:-$HOME/.dotfiles}"
            local example_file="$dotfiles_dir/.profile.local.example"
            if [ -f "$example_file" ]; then
                cp "$example_file" "$profile_local"
                echo "Created ~/.profile.local from example"
                echo "  Edit $profile_local to add your tokens."
            else
                echo "Warning: Example file not found: $example_file"
                echo "  You can create ~/.profile.local manually."
            fi
            ;;
        *)
            echo "Skipped. You can create it manually later."
            echo "  Example: cp ~/.dotfiles/.profile.local.example ~/.profile.local"
            ;;
    esac
}

main() {
    ls -lah "$WORKDIR"

    echo 'Setting up git flow...'
    sh $WORKDIR/dotfiles-git

    echo "Symlinking state dir..."
    mkdir -p "$HOME/.local/state/dotstow"
    ln -s "$HOME/.dotfiles" "$HOME/.local/state/dotstow/dotfiles"

    echo 'Symlinking vim rc files...'
    cp -f $HOME/.dotfiles/linux/vim/.vimrc ~/.vimrc
    cp -f $HOME/.dotfiles/linux/vim/.virc ~/.virc

    echo 'Installing dotstow...'
    ./dotfiles-dotstow

    echo 'Setting up bash fzf...'
    git clone -q --depth 1 https://github.com/junegunn/fzf.git ~/.fzf || true
    ~/.fzf/install

    echo 'Setting up bash fasd...'
    git clone -q --depth 1 https://github.com/clvv/fasd.git ~/.fasd || true

    echo 'Setting up Tmux Plugin Manager...'
    mkdir -p ~/.tmux/plugins
    git clone -q --depth 1 https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm || true

    echo 'Setting up Starship prompt...'
    mkdir -p ~/.local/bin/org.jcchikikomori.dotfiles/bin
    curl -fsSL https://starship.rs/install.sh | sh -s -- -b ~/.local/bin/org.jcchikikomori.dotfiles/bin -f

    echo 'Setting up Antigen...'
    curl -L https://git.io/antigen >"$HOME/antigen.zsh"

    # https://github.com/alacritty/alacritty-theme
    echo 'Setting up Alacritty themes...'
    mkdir -p ~/.config/alacritty/themes
    git clone https://github.com/alacritty/alacritty-theme ~/.config/alacritty/themes

    echo 'Setting up some Nerd Fonts...'
    sh $WORKDIR/dotfiles-nerf JetBrainsMono FiraCode
    sh $WORKDIR/dotfiles-nerf --smoke-test

    # Check if running on Termux
    if [ -n "$PREFIX" ] && echo "$PREFIX" | grep -q "com.termux"; then
        echo ""
        echo "=== Termux Environment Detected ==="
        echo "Only Python (pyenv) is officially supported on Linux distributions."
        echo "Other language managers (Ruby, PHP, Java, NodeJS) may have compatibility issues."
        echo "You can install them manually later if needed."
        echo ""
        prompt_installation "python" "dotfiles-python"
        prompt_installation "pre-commit" "dotfiles-python--pre-commit"
        prompt_installation "commitizen (cz)" "dotfiles-python--commitizen"
        prompt_installation "Vim with plugins" "dotfiles-vim"
    else
        prompt_installation "python with pyenv" "dotfiles-python"
        prompt_installation "pre-commit" "dotfiles-python--pre-commit"
        prompt_installation "commitizen (cz)" "dotfiles-python--commitizen"
        prompt_installation "Ruby with rbenv" "dotfiles-ruby"
        prompt_installation "SDKMAN" "dotfiles-java-sdkman"
        prompt_installation "NodeJS with NVM" "dotfiles-nodejs"
        prompt_installation "PHP with phpenv" "dotfiles-php"
        prompt_installation "Copyparty file server" "dotfiles-copyparty"
        prompt_installation "Vim with plugins" "dotfiles-vim"
    fi

    if [ -z "$PREFIX" ] || ! echo "$PREFIX" | grep -q "com.termux"; then
        DOTFILES_DIR="${DOTFILES_PATH:-$HOME/.dotfiles}"
        if command -v devtools-opencode > /dev/null 2>&1; then
            prompt_installation "opencode AI coding agent" "devtools-opencode install"
        else
            echo "Warning: devtools-opencode not found on PATH. Skipping."
            echo "  Make sure the systems stow package is installed."
        fi
    fi

    echo 'Setting up oh-my-zsh...'
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    echo 'Installing zsh plugins...'
    local ZSH_CUSTOM_DIR=$HOME/.oh-my-zsh/custom
    local ZSH_CUSTOM_PLUGINS_DIR=$ZSH_CUSTOM_DIR/plugins
    git clone https://github.com/bobthecow/git-flow-completion.git $ZSH_CUSTOM_PLUGINS_DIR/git-flow-completion
    git clone https://github.com/zsh-users/zsh-autosuggestions.git $ZSH_CUSTOM_PLUGINS_DIR/zsh-autosuggestions
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git $ZSH_CUSTOM_PLUGINS_DIR/zsh-syntax-highlighting
    git clone https://github.com/zdharma-continuum/fast-syntax-highlighting.git $ZSH_CUSTOM_PLUGINS_DIR/fast-syntax-highlighting
    git clone --depth 1 -- https://github.com/marlonrichert/zsh-autocomplete.git $ZSH_CUSTOM_PLUGINS_DIR/zsh-autocomplete
    git clone https://github.com/larkery/zsh-histdb.git $ZSH_CUSTOM_PLUGINS_DIR/zsh-histdb

    echo 'Setting up ~/.profile.local for user customizations...'
    setup_profile_local

    cd "$ORIGINAL_DIR"
    rm -rf "$WORKDIR"
}

echo 'Setting up scripts...'
setup_directory
if [ $? -ne 0 ]; then
    echo "Error: Failed to complete setting up scripts! Exiting..." >&2
    exit 1
fi

echo 'Executing post-setup...'
main

