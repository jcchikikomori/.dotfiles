#!/bin/sh

echo "Installing pre-commit hooks..."
WORKDIR=$(mktemp -d)
PYENV_ROOT="$HOME/.pyenv"
trap 'rm -rf "$WORKDIR"' EXIT

setup() {
  # Check if pre-commit is installed
  if command -v pre-commit &> /dev/null; then
      echo "pre-commit is already installed. Exiting..."
      exit 0
  else
      echo "pre-commit not found. Installing pre-commit..."
      if ! pip install --user pre-commit; then
          echo "Error: Failed to install pre-commit." >&2
          exit 1
      fi
  fi
}

# Detect Termux environment and install Python accordingly
if [ -n "$PREFIX" ] && echo "$PREFIX" | grep -q "com.termux"; then
    echo ""
    echo "=== Termux Environment Detected ==="
    echo "Installing pre-commit via pip in Termux..."
    setup
else
    # Check if pre-commit is already available
    if command -v pre-commit &> /dev/null; then
        echo "pre-commit is already installed. Exiting..."
        exit 0
    fi

    # Strategy 1: pip or pip3 is directly available
    if command -v pip &> /dev/null; then
        echo "Installing pre-commit via pip..."
        pip install --user pre-commit || { echo "Error: Failed to install pre-commit via pip." >&2; exit 1; }
        exit 0
    fi
    if command -v pip3 &> /dev/null; then
        echo "Installing pre-commit via pip3..."
        pip3 install --user pre-commit || { echo "Error: Failed to install pre-commit via pip3." >&2; exit 1; }
        exit 0
    fi

    # Strategy 2: uv is available (uv tool install)
    if command -v uv &> /dev/null; then
        echo "Installing pre-commit via uv tool..."
        uv tool install pre-commit || { echo "Error: Failed to install pre-commit via uv." >&2; exit 1; }
        exit 0
    fi

    # Strategy 3: pyenv is available
    if [ -d "$PYENV_ROOT" ]; then
        echo "pyenv found. Loading pyenv environment..."
        export PATH="$PYENV_ROOT/bin:$PATH"
        eval "$(pyenv init -)"

        LATEST_VERSION=$(pyenv versions --bare | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -n 1)
        if [ -n "$LATEST_VERSION" ]; then
            echo "Setting Python $LATEST_VERSION as the global version..."
            pyenv global "$LATEST_VERSION"
            pyenv rehash
            setup
            exit 0
        else
            echo "Error: No Python versions found in pyenv. Please install a Python version using pyenv." >&2
            exit 1
        fi
    fi

    # No supported Python manager found
    echo "Error: No supported Python manager found." >&2
    echo "  Supported: pip/pip3, uv, pyenv" >&2
    echo "  Please install Python via dotfiles-python first." >&2
    exit 1
fi
