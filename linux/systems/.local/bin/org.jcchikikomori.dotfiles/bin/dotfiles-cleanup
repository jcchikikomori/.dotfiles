#!/bin/sh

# Issues occurring with the script: vim, zsh & systems (.profile file)

DOTSTOW_BIN=$(command -v dotstow 2>/dev/null)
if [ -z "$DOTSTOW_BIN" ] && [ -x "$HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotstow" ]; then
  DOTSTOW_BIN="$HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotstow"
fi
if [ -z "$DOTSTOW_BIN" ] && [ -x "/usr/local/bin/dotstow" ]; then
  DOTSTOW_BIN="/usr/local/bin/dotstow"
fi
if [ -z "$DOTSTOW_BIN" ] && [ -x "/opt/homebrew/bin/dotstow" ]; then
  DOTSTOW_BIN="/opt/homebrew/bin/dotstow"
fi

# Check if dotstow is available and executable
if [ -z "$DOTSTOW_BIN" ]; then
  echo "Error: dotstow command not found in PATH or known install locations. Aborting." >&2
  exit 1
fi

echo 'Unstowing...'
if [ "$(uname -s 2>/dev/null)" = "Darwin" ]; then
  "$DOTSTOW_BIN" unstow git antigen tmux tmuxp vscode systems opencode claude
else
  "$DOTSTOW_BIN" unstow git antigen tmux tmuxp vscode dxvk bash opencode claude
  "$DOTSTOW_BIN" unstow flatpak systems wireplumber
fi

# Backup helper: copies file/dir to $HOME/.backups if it exists and is not a symlink
backup_item() {
  local src="$1"
  local label="${2:-$(basename "$src")}"
  if [ -e "$src" ] && [ ! -L "$src" ]; then
    mkdir -p "$HOME/.backups"
    cp -a "$src" "$HOME/.backups/"
    echo "  backed up $label"
  fi
}

echo 'Backing up...'
mkdir -p "$HOME/.backups"
mkdir -p "$HOME/.backups/opencode"
mkdir -p "$HOME/.binbackups"

backup_item "$HOME/.ssh"
backup_item "$HOME/.zsh"
backup_item "$HOME/.zshrc"
backup_item "$HOME/.zprofile"
backup_item "$HOME/.profile"
backup_item "$HOME/.zshrc.pre-oh-my-zsh"
backup_item "$HOME/.git"
backup_item "$HOME/.config/opencode/memory_data"
backup_item "$HOME/.opencode"
backup_item "$HOME/.claude"
backup_item "$HOME/.agents"

echo 'Cleaning up tmux...'
rm -f "$HOME/.tmux.conf.local"
rm -rf "$HOME/.config/tmux-powerline"

echo 'Cleaning up VSCode...'
backup_item "$HOME/.vscode-server/extensions/extensions.json"
rm -rf "$HOME/.vscode"
rm -rf "$HOME/.vscode-server"
rm -rf "$HOME/.config/Code/User/prompts"
# Restore extensions.json as a real file (not stowed)
if [ -f "$HOME/.backups/extensions.json" ]; then
  mkdir -p "$HOME/.vscode-server/extensions"
  cp -f "$HOME/.backups/extensions.json" "$HOME/.vscode-server/extensions/extensions.json"
  echo "  restored extensions.json as real file"
fi

echo 'Cleaning up other files...'
rm -f "$HOME/.gitconfig"
rm -f "$HOME/.alacritty.yml"
rm -f "$HOME/.antigenrc"
rm -f "$HOME/bash_completion.d"
rm -f "$HOME/default.yml"
rm -f "$HOME/.dxvk"
rm -f "$HOME/.hushlogin"
rm -f "$HOME/.zprofile"
rm -f "$HOME/.profile"
rm -f "$HOME/.tmuxp"
rm -f "$HOME/.vimrc"
rm -f "$HOME/.virc"
rm -f "$HOME/.gnupg/gpg.conf"
rm -f "$HOME/.gnupg/gpg-agent.conf"
rm -f "$HOME/.zsh"
rm -f "$HOME/.zshrc"
rm -f "$HOME/.zshrc.pre-oh-my-zsh"
rm -f "$HOME/.zalias"
rm -f "$HOME/.zfunctions"
rm -f "$HOME/.git"
rm -f "$HOME/.config/wireplumber/wireplumber.conf.d/51-priority-override.conf"
rm -f "$HOME/.config/kwinrulesrc"
rm -f "$HOME/.config/alacritty/alacritty.toml"
rm -f "$HOME/.config/autostart/com.discordapp.Discord.desktop"
rm -f "$HOME/.config/htop/htoprc"
rm -f "$HOME/.pyenv/version"
rm -f "$HOME/.ruby-version"
rm -f "$HOME/.gemrc"
rm -f "$HOME/.railsrc"
rm -f "$HOME/.supermodel/Config/Supermodel.ini"

if [ -L "$HOME/.local/share/kwin/scripts" ]; then
  rm -f "$HOME/.local/share/kwin/scripts"
fi

if [ -L "$HOME/.local/share/kservices5" ]; then
  rm -f "$HOME/.local/share/kservices5"
fi

# Clean up old opencode directory structure (moved to linux/opencode)
if [ -d "$HOME/.dotfiles/opencode" ] && [ ! -f "$HOME/.dotfiles/opencode/.config/opencode/opencode.jsonc" ]; then
  echo 'Cleaning up old opencode directory...'
  rm -rf "$HOME/.dotfiles/opencode"
fi

# Backup oh-my-opencode state before cleanup (these are real files, not symlinks)
mkdir -p "$HOME/.backups/opencode/omo"
for omo_file in "$HOME/.config/opencode/oh-my-openagent.json" \
                "$HOME/.config/opencode/oh-my-opencode.json" \
                "$HOME/.config/opencode/oh-my-opencode-slim.json"; do
    if [ -f "$omo_file" ] && [ ! -L "$omo_file" ]; then
        cp "$omo_file" "$HOME/.backups/opencode/omo/"
    fi
done

# Clean up opencode symlinks, old folders & stale files before restow
# NOTE: opencode.jsonc is now a real file (copied from template), not a symlink — do NOT remove it
rm -f "$HOME/.config/opencode/opencode-mem.json"
rm -f "$HOME/.config/opencode/package.json"
rm -f "$HOME/.config/opencode/bun.lock"
rm -f "$HOME/.config/opencode/tui.json"
rm -f "$HOME/.config/opencode/AGENTS.md"
rm -f "$HOME/.config/opencode/GIT_COMMIT_GUARD.md"
# .env.example removed — tokens now live in ~/.profile.local
rm -f "$HOME/.zopencode"
rm -rf "$HOME/.opencode"
rm -rf "$HOME/.config/opencode/agent"
rm -rf "$HOME/.config/opencode/agents"
rm -rf "$HOME/.config/opencode/plugin"
rm -rf "$HOME/.config/opencode/plugins"
rm -rf "$HOME/.config/opencode/skills"

# Clean up claude symlinks & stale files before restow
# Note: settings.json and projects/ are user data, don't remove
rm -f "$HOME/.claude/CLAUDE.md"
rm -f "$HOME/.claude/.gitignore"
rm -f "$HOME/.claude/.gitkeep"
# Clean up .agents/skills (generated by devtools-ai)
rm -rf "$HOME/.agents/skills"
# mkdir -p "$HOME/.agents/skills"

# Create some files
# rm -f $HOME/.config/opencode/memory_data
mkdir -p "$HOME/.config/opencode/memory_data"

# Backup SSH directory
echo 'y' || cp -rf "$HOME/.ssh" "$HOME/.ssh-backup"
